          </geometry>
          <material>
            <diffuse>0.6 0.4 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Table legs -->
    <model name='table_leg1'>
      <static>true</static>
      <link name='link'>
        <pose>-2.6 1.3 0.2 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.05 0.05 0.4</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.05 0.05 0.4</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.5 0.35 0.15 1</diffuse>
          </material>
        </visual>
