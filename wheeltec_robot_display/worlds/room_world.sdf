    <model name='obstacle2'>
      <static>true</static>
      <link name='link'>
        <pose>2 1.5 0.15 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.25 0.25 0.3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
