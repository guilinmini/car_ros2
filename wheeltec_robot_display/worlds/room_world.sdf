    </model>

    <!-- Obstacles for navigation -->
    <model name='obstacle1'>
      <static>true</static>
      <link name='link'>
        <pose>1 0 0.15 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
