<sdf version='1.9'>
  <world name='room_world'>
    <!-- Physics settings -->
    <physics name='1ms' type='ignored'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- Gazebo plugins -->
    <plugin name='gz::sim::systems::Physics' filename='ignition-gazebo-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands' filename='ignition-gazebo-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='ignition-gazebo-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact' filename='ignition-gazebo-contact-system'/>
    <plugin name='ignition::gazebo::systems::Sensors' filename='ignition-gazebo-sensors-system'/>

    <!-- Environment -->
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic'/>

    <!-- Scene settings -->
    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.8 0.85 0.9 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
    </scene>

    <!-- Ground plane (floor) -->
    <model name='floor'>
      <static>true</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/DarkGrey</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <!-- Room 1: Main Room (8m x 6m) -->
    <!-- Back wall -->
    <model name='room1_back_wall'>
      <static>true</static>
      <link name='link'>
        <pose>0 3 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>8 0.2 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>8 0.2 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Front wall -->
    <model name='room1_front_wall'>
      <static>true</static>
      <link name='link'>
        <pose>0 -3 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>8 0.2 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>8 0.2 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Left wall -->
    <model name='room1_left_wall'>
      <static>true</static>
      <link name='link'>
        <pose>-4 0 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.2 6 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.2 6 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Right wall with door opening -->
    <model name='room1_right_wall_bottom'>
      <static>true</static>
      <link name='link'>
        <pose>4 -2 0.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.2 1 1</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.2 1 1</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='room1_right_wall_top'>
      <static>true</static>
      <link name='link'>
        <pose>4 -2 2.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.2 1 1</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.2 1 1</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='room1_right_wall_left'>
      <static>true</static>
      <link name='link'>
        <pose>4 -3 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.2 0.8 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.2 0.8 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='room1_right_wall_right'>
      <static>true</static>
      <link name='link'>
        <pose>4 -1 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.2 4.2 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.2 4.2 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Room 2: Side Room (4m x 6m) -->
    <!-- Back wall -->
    <model name='room2_back_wall'>
      <static>true</static>
      <link name='link'>
        <pose>8 3 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>4 0.2 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>4 0.2 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.85 0.85 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Front wall -->
    <model name='room2_front_wall'>
      <static>true</static>
      <link name='link'>
        <pose>8 -3 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>4 0.2 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>4 0.2 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.85 0.85 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Right wall -->
    <model name='room2_right_wall'>
      <static>true</static>
      <link name='link'>
        <pose>10 0 1.5 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.2 6 3</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.2 6 3</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.85 0.85 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Furniture: Table in Room 1 -->
    <model name='table'>
      <static>true</static>
      <link name='link'>
        <pose>-2 1 0.4 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>1.5 0.8 0.05</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>1.5 0.8 0.05</size>
