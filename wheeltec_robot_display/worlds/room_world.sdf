    </model>

    <model name='table_leg4'>
      <static>true</static>
      <link name='link'>
        <pose>-1.4 0.7 0.2 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.05 0.05 0.4</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.05 0.05 0.4</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.5 0.35 0.15 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Furniture: Bookshelf in Room 1 -->
    <model name='bookshelf'>
      <static>true</static>
      <link name='link'>
        <pose>-3.5 -1 0.6 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.8 0.3 1.2</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.8 0.3 1.2</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.5 0.35 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Furniture: Chair -->
    <model name='chair'>
      <static>true</static>
      <link name='link'>
        <pose>-2 0 0.25 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.4 0.4 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.4 0.4 0.5</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.3 0.3 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Furniture: Cabinet in Room 2 -->
    <model name='cabinet'>
      <static>true</static>
      <link name='link'>
        <pose>8 2 0.4 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>1.0 0.5 0.8</size>
            </box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box>
              <size>1.0 0.5 0.8</size>
            </box>
          </geometry>
          <material>
            <diffuse>0.55 0.4 0.25 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Furniture: Desk in Room 2 -->
    <model name='desk'>
      <static>true</static>
      <link name='link'>
        <pose>9 -1 0.4 0 0 0</pose>
        <collision name='collision'>
          <geometry>
            <box>
              <size>1.2 0.6 0.05</size>
            </box>
